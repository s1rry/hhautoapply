# === Режим ===
# single — одиночный (self-host): один пользователь из этого .env, полный функционал.
# multi  — мультиюзерный (облако): много пользователей, тарифы, per-user hh.
MODE=single

# === Безопасность ===
# Ключ шифрования hh-токенов и Telegram-сессий в БД (любая длинная случайная фраза).
# Обязательно задай в проде. Смена ключа сделает уже зашифрованные записи нечитаемыми.
ENCRYPTION_KEY=

# === Telegram ===
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_CHAT_ID=your_chat_id_here

# === ИИ ===
# Провайдер: openai (любой OpenAI-совместимый эндпоинт) | anthropic
AI_PROVIDER=openai
# По умолчанию Cerebras (бесплатный, быстрый). Ключ: https://cloud.cerebras.ai
AI_API_KEY=csk-xxxxx
AI_BASE_URL=https://api.cerebras.ai/v1
AI_MODEL=gpt-oss-120b
# Отдельная дешёвая модель для оценки вакансий (скоринг возвращает одно число).
# Пусто = использовать AI_MODEL. Скоринг — основная статья расходов на ИИ.
AI_SCORE_MODEL=
# Модель писем на бесплатном тарифе (платным пишет AI_MODEL). Пусто = всем одна.
AI_LETTER_MODEL_FREE=
# Пул эндпоинтов для скоринга — самая массовая операция, её выгодно гонять
# на бесплатных тирах. Формат: url|ключ|модель, несколько — через ';'.
# Ключи перебираются по кругу; отвалились все — запрос уйдёт на AI_BASE_URL.
# Бери ключи у РАЗНЫХ провайдеров: лимиты у них независимые, а несколько
# аккаунтов у одного — нарушение правил и риск потерять все ключи разом.
#   Cerebras https://cloud.cerebras.ai        url https://api.cerebras.ai/v1        модель gpt-oss-120b
#   Groq     https://console.groq.com/keys    url https://api.groq.com/openai/v1    модель llama-3.3-70b-versatile
#   Gemini   https://aistudio.google.com/apikey  url https://generativelanguage.googleapis.com/v1beta/openai  модель gemini-2.0-flash
AI_SCORE_POOL=
# Своя модель / другой провайдер — сменить только эти 3 строки, напр.:
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Mistral:    AI_BASE_URL=https://api.mistral.ai/v1     AI_MODEL=mistral-small-latest
#   DeepSeek:   AI_BASE_URL=https://api.deepseek.com      AI_MODEL=deepseek-chat
# Anthropic нужен только если AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Контакты для подписи в шаблонных письмах (одиночный режим)
CONTACTS=your-email@example.com, tg @your_telegram

# === Database ===
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter
REDIS_URL=redis://localhost:6379/0

# === Job Platforms ===
HH_LOGIN=your_hh_email
HH_PASSWORD=your_hh_password
WORKSPACE_LOGIN=your_workspace_email
WORKSPACE_PASSWORD=your_workspace_password
GEEKJOB_LOGIN=your_geekjob_email
GEEKJOB_PASSWORD=your_geekjob_password

# === Resume / Profile ===
RESUME_TEXT_PATH=configs/resume.txt
DESIRED_POSITION=Python Backend Developer
DESIRED_SALARY_MIN=200000
DESIRED_SALARY_MAX=400000

# === Parsing ===
CHECK_INTERVAL_SEC=300
PROXY_URL=
BROWSER_HEADLESS=true

# === Anti-ban ===
MIN_DELAY_SEC=3
MAX_DELAY_SEC=12
MAX_APPLIES_PER_DAY=30

# === Оплата (только MODE=multi) ===
SUBSCRIPTION_PRICE=299
SUBSCRIPTION_DAYS=30
# ЮMoney: номер кошелька и секрет HTTP-уведомлений (настройки кошелька ЮMoney)
YOOMONEY_WALLET=
YOOMONEY_SECRET=
# ЮKassa (магазин): shopId и секретный ключ из ЛК ЮKassa.
# Вебхук в ЛК ЮKassa: https://<домен>:PORT/yookassa, событие payment.succeeded
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/YourBot
# Крипта для ручной оплаты (подтверждает админ через /grant)
CRYPTO_TON=
CRYPTO_USDT_TRC20=
PAYMENT_WEBHOOK_PORT=8088
# Бета: первым N пользователям — полный доступ бесплатно на BETA_DAYS
# Пробный период каждому новому (true) или только первым N (false)
BETA_FOR_ALL=true
BETA_FULL_ACCESS_SLOTS=50
BETA_DAYS=7
